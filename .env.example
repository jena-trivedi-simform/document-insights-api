# ── MongoDB ──────────────────────────────────────────────────────────────────
# Connection string. Use the service name as the host inside docker-compose.
MONGODB_URL=

# Database name. Change to document_insights_test when running pytest.
MONGODB_DB_NAME=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=r

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Maximum number of documents a single user may have in queued+processing state.
MAX_ACTIVE_PER_USER=

# ── Content cache ─────────────────────────────────────────────────────────────
# How long (seconds) a computed summary is kept in Redis. Default: 24 hours.
CONTENT_CACHE_TTL=

# ── Worker ────────────────────────────────────────────────────────────────────
# How often (seconds) the worker polls for new jobs when the queue is empty.
WORKER_POLL_INTERVAL=

# Simulated processing time range (seconds).
WORKER_MIN_DELAY=
WORKER_MAX_DELAY=

# Fraction of jobs that randomly fail (0.0 – 1.0). 0.1 = 10%.
WORKER_FAILURE_RATE=

# Retry mechanism: how many times to retry a failed job before giving up.
MAX_RETRIES=
# Base delay in seconds for exponential backoff (delay = base * 2^attempt).
# Attempt 0 → 5s, attempt 1 → 10s, attempt 2 → 20s.
RETRY_BACKOFF_BASE=

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=
